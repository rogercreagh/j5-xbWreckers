<?xml version="1.0" encoding="UTF-8"?>
<extension type="template" client="site" method="upgrade">
	<name>xbwreckers</name>
	<version>1.0.5.3</version>
	<creationDate>16th March 2026</creationDate>
	<author>Roger C-O</author>
	<authorEmail>roger@crosborne.uk</authorEmail>
	<copyright>(C) 2026,2017 Roger C-O and Open Source Matters, Inc.</copyright>
	<description>Specific for WreckersRadio webiste, forked from Cassopedia v1.0</description>
	<inheritable>1</inheritable>
	<scriptfile>install.xbwreckers.php</scriptfile>	
	<files>
		<filename>component.php</filename>
		<filename>error.php</filename>
		<filename>index.php</filename>
		<filename>joomla.asset.json</filename>
		<filename>offline.php</filename>
		<filename>templateDetails.xml</filename>
		<folder>html</folder>		
	</files>
	<media destination="templates/site/xbwreckers" folder="media">
		<folder>js</folder>
		<folder>css</folder>
		<folder>scss</folder>
		<folder>images</folder>
	</media>

    <!-- CHANGE THESE TO GITHUB ONCE PUBLISHED -->
    <changelogurl>https://raw.githubusercontent.com/rogercreagh/j5-xbWreckers/main/changelog_xbwreckers.xml</changelogurl>
    <updateservers>
	    <server type="extension" name="xbAzHead Module Updates">
	    	https://raw.githubusercontent.com/rogercreagh/j5-xbWreckers/main/update_xbwreckers.xml
	    </server>
			<!-- https://raw.githubusercontent.com/rogercreagh/j5-xbMusic/main/update_xbmusic.xml -->
	</updateservers>
	
	<positions>
		<position>xbazhead</position>
		<position>xbnlhead</position>
		<position>topbar</position>
		<position>below-top</position>
		<position>menu</position>
		<position>streamer</position>
		<position>search</position>
		<position>banner</position>
		<position>top-a</position>
		<position>top-b</position>
		<position>main-top</position>
		<position>main-bottom</position>
		<position>breadcrumbs</position>
		<position>sidebar-left</position>
		<position>sidebar-right</position>
		<position>bottom-a</position>
		<position>bottom-b</position>
		<position>footer</position>
		<position>debug</position>
		<!-- used directly in the error.php and included here so the position will appear in the list of available positions -->
		<position>error-403</position>
		<position>error-404</position>
	</positions>
	<languages folder="language">
		<language tag="en-GB">en-GB/tpl_xbwreckers.ini</language>
		<language tag="en-GB">en-GB/tpl_xbwreckers.sys.ini</language>
	</languages>
	<config>
		<fields name="params">
			<fieldset name="advanced">
				<field
					name="logoFileLeft"
					type="media"
					schemes="http,https,ftp,ftps,data,file"
					validate="url"
					relative="true"
					default=""
					label="Logo for Header Left"
					description="Defaults to WR circle logo. Size 250x250"
				/>

				<field
					name="logoFileCentre"
					type="media"
					schemes="http,https,ftp,ftps,data,file"
					validate="url"
					relative="true"
					default=""
					label="Logo for Header Centre"
					description="Defaults to Text WR logo. Size 500x189"
				/>

				<field
					name="siteSlug"
					type="text"
					hint="TPL_XBWRECKERS_SLUG_HINT"
					default=""
					label="Short Slug"
					description="Appears bold text under text logo in centre of header"
					filter="string"
				/>

				<field
					name="siteDescription"
					type="textarea"
					default=""
					rows="2"
					label="Main Description"
					description="Appears below slug in plain text centred"
					filter="string"
					hint="TPL_XBWRECKERS_DESC_HINT"
				/>

				<field
					name="siteDescription2"
					type="text"
					default=""
					rows="1"
					label="Additional Description"
					description="Appears below Description only on displays >900px wide"
					filter="string"
					hint="TPL_XBWRECKERS_DESC2_HINT"
				/>

				<field
					name="colorName"
					type="filelist"
					label="TPL_XBWRECKERS_COLOR_NAME_LABEL"
					default="colors_standard"
					fileFilter="^custom.+[^min]\.css$"
					exclude="^colors.+"
					stripext="true"
					hide_none="true"
					hide_default="true"
					directory="media/templates/site/xbwreckers/css/global/"
					validate="options"
					>
					<option value="colors_standard">TPL_XBWRECKERS_COLOR_NAME_STANDARD</option>
					<option value="colors_alternative">TPL_XBWRECKERS_COLOR_NAME_ALTERNATIVE</option>
				</field>

				<field
					name="fluidContainer"
					type="radio"
					layout="joomla.form.field.radio.switcher"
					default="0"
					label="TPL_XBWRECKERS_FLUID_LABEL"
					>
					<option value="0">TPL_XBWRECKERS_STATIC</option>
					<option value="1">TPL_XBWRECKERS_FLUID</option>
				</field>

				<field
					name="stickyHeader"
					type="radio"
					label="TPL_XBWRECKERS_STICKY_LABEL"
					layout="joomla.form.field.radio.switcher"
					default="0"
					filter="integer"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>

				<field
					name="backTop"
					type="radio"
					label="TPL_XBWRECKERS_BACKTOTOP_LABEL"
					layout="joomla.form.field.radio.switcher"
					default="0"
					filter="integer"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
				<field
					name="testMode"
					type="radio"
					label="Running on Test Server"
					layout="joomla.form.field.radio.switcher"
					default="0"
					filter="integer"
					>
					<option value="0">JNO</option>
					<option value="1">JYES</option>
				</field>
			</fieldset>
		</fields>
	</config>
</extension>
